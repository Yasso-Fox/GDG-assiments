  name = stdin.readLineSync();
  print("day of birth");
  x = int.parse(stdin.readLineSync()!);
  birth.add(x);
  print("month of birth");
  x = int.parse(stdin.readLineSync()!);
  birth.add(x);
  print("year of birth");
  x = int.parse(stdin.readLineSync()!);
  birth.add(x);

  Students_data SD = Students_data(id, birth, name!);
  SD.data();
}
