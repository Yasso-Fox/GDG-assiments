import 'dart:io';

class Students_data {
  late int ID;
  late String name;
  late List birth;
  Students_data(this.ID, this.birth, this.name);

  void data() {
    print("name : $name\nID : $ID\nBirth day/month/year : $birth");
  }
}

late int id;
String? name;
late int x;
late List birth = [];

void main() {
  print("Wjat is the Student ID");
