import 'dart:io';

class car {
  late String color;
  late int price;
  late String brand;

  car(this.color, this.price, this.brand);

  void carDetails() {
    print(
      "Brand of the car $brand \ncolor of the car $color \nPrice of the car $price"
    );
  }

  double FixPrice() {
    return price * 0.1;
  }
}

String? colorOfCar;
String? nameOfBrand;
int? priceOfCar;

void main() {
  print("waht is the name of the brand");
  nameOfBrand = stdin.readLineSync();
  print("What is the color of the car");
  colorOfCar = stdin.readLineSync();
  print("What is the price of the car");
  String? x = stdin.readLineSync();
  priceOfCar = int.parse(x!);

  car Car = car(colorOfCar!, priceOfCar!, nameOfBrand!);

  Car.carDetails();
  print(Car.FixPrice());
}
